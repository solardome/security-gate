{
  "policy_version": "full-test-v1",
  "requires_signed_artifact": true,
  "requires_provenance_level": "level2",
  "rules": [
    {
      "id": "R-RELEASE-HIGH-TIGHTEN",
      "description": "Tighten release when high vulnerability risk and moderate/high-risk change.",
      "enabled": true,
      "stage_scope": ["release", "prod"],
      "when": {
        "release_risk_gte": 45,
        "release_risk_lte": 100,
        "trust_score_gte": 0,
        "trust_score_lt": 80,
        "max_finding_risk_gte": 60,
        "max_finding_risk_lte": 100,
        "domain_in": ["VULNERABILITY", "CONFIG"],
        "severity_in": ["HIGH", "CRITICAL"],
        "change_type_in": ["moderate", "high_risk"],
        "exposure_in": ["internal", "public"],
        "fix_available_in": ["true", "false", "unknown"],
        "has_hard_stop": false
      },
      "then": {
        "decision": "WARN",
        "warn_to_block": false,
        "add_required_steps": [
          "FIX_VULN",
          "VERIFY_PROVENANCE",
          "IMPROVE_TRUST"
        ],
        "require_accepted_risk": {
          "selector": {
            "type": "top_findings",
            "top_n": 2
          },
          "scope": "scoring_set"
        }
      },
      "tags": ["release", "risk", "governance"]
    },
    {
      "id": "R-PR-NOISE-BUDGET",
      "description": "Apply PR noise budget top-K for signal reduction in pull requests.",
      "enabled": true,
      "stage_scope": ["pr"],
      "when": {},
      "then": {
        "noise_budget_top_k": 5
      },
      "tags": ["pr", "noise-budget"]
    },
    {
      "id": "R-PROD-WARN-BLOCK",
      "description": "Escalate WARN to BLOCK in prod unless allow_warn_in_prod coverage is complete.",
      "enabled": true,
      "stage_scope": ["prod"],
      "when": {
        "release_risk_gte": 26,
        "trust_score_lt": 50
      },
      "then": {
        "warn_to_block": true,
        "add_required_steps": [
          "ADD_ACCEPTED_RISK"
        ],
        "require_accepted_risk": {
          "selector": {
            "type": "all_high_or_critical"
          },
          "scope": "considered_set"
        }
      },
      "tags": ["prod", "escalation"]
    }
  ],
  "exceptions": [
    {
      "id": "EX-TRIVY-FP-001",
      "description": "Known false-positive advisory for sample package in non-prod environments.",
      "stage_scope": ["pr", "main", "release"],
      "environment_scope": ["dev", "staging"],
      "finding_selector": {
        "fingerprint": "",
        "domain": "VULNERABILITY",
        "cve_id": "CVE-2024-9999",
        "title_contains": "Example vulnerable dependency",
        "location_contains": "app/backend",
        "source_scanner": "trivy",
        "severity": "HIGH"
      },
      "expires_at": "2027-01-15T00:00:00Z",
      "owner": "security-team",
      "rationale": "Temporary suppression until upstream advisory metadata is corrected."
    }
  ]
}
